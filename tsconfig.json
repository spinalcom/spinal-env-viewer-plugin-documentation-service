{
	"compilerOptions": {
		"baseUrl": "./",
		"ignoreDeprecations": "6.0",
		"skipLibCheck": true,
		"target": "ES2020",
		"module": "commonjs",
		"rootDir": "./src",
		"outDir": "dist",
		"declarationDir": "declarations",
		"esModuleInterop": false,
		"typeRoots": ["node_modules/@types", "src/types", "jest"],
		"declaration": true,
		"sourceMap": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules"]
}
